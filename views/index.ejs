<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Farsa | FILE UPLOADER</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar">
        <div class="container">
            <h1 class="logo">Farsa<span>UPLOADER</span></h1>
        </div>
    </nav>

    <main class="container main-grid">
        <!-- Area Kiri: Uploader -->
        <section class="uploader-section">
            <div class="card uploader-card">
                <div id="drop-zone" class="drop-zone">
                    <p>Drag & drop files here or click to browse</p>
                    <input type="file" id="file-input" multiple hidden>
                    <button class="btn btn-secondary" onclick="document.getElementById('file-input').click()">Select Files</button>
                </div>

                <div id="preview-container" class="preview-container hidden">
                    <h3>Ready to Upload</h3>
                    <div id="file-list" class="file-list"></div>
                    <button id="upload-btn" class="btn btn-primary full-width">Upload Now</button>
                </div>

                <div id="progress-container" class="progress-container hidden">
                    <div class="progress-bar">
                        <div id="progress-fill" class="progress-fill"></div>
                    </div>
                    <p id="progress-text">0%</p>
                </div>

                <div id="result-container" class="result-container hidden">
                    <h3>Upload Success!</h3>
                    <div id="result-list" class="file-list"></div>
                </div>
            </div>
        </section>

        <!-- Area Kanan: Stats & History -->
        <aside class="sidebar-section">
            <div class="card stats-card">
                <h2>Statistics</h2>
                <div class="stats-grid">
                    <div class="stat-item">
                        <small>Total Files</small>
                        <p id="stat-count">0</p>
                    </div>
                    <div class="stat-item">
                        <small>Total Storage</small>
                        <p id="stat-size">0 KB</p>
                    </div>
                </div>
            </div>

            <div class="card history-card">
                <h2>My History</h2>
                <div id="history-list" class="history-list">
                    <p class="empty-state">No uploads yet.</p>
                </div>
            </div>
        </aside>
    </main>

    <section class="container">
        <div class="card donation-card">
            <div class="donation-content">
                <div>
                    <h2>Support Our Project</h2>
                    <p>Membantu kami menjaga server tetap menyala dan mendukung pengembangan lebih lanjut.</p>
                </div>
                <div class="qris-wrapper">
                    <img src="/donate/qris.jpg" alt="QRIS Donation" onerror="this.src='https://placehold.co/200x250?text=QRIS+IMAGE'">
                </div>
            </div>
        </div>
    </section>

    <footer class="footer">
        <div class="container">
            <p>&copy; 2026 NeoDrop. Built for performance and style.</p>
        </div>
    </footer>

    <script src="/js/app.js"></script>
</body>
</html>
